# AbirQu provider credentials template
# Copy to .env and fill in the values you have.

# IBM Quantum
IBM_QUANTUM_TOKEN=
# Alternative alias accepted by AbirQu
IBM_TOKEN=

# AWS Braket
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# Azure Quantum
AZURE_QUANTUM_RESOURCE_ID=
# Alternative alias accepted by AbirQu
AZURE_RESOURCE_ID=

# IonQ
IONQ_API_KEY=

# Google Quantum / Cirq
GOOGLE_CLOUD_PROJECT=
# Alternative alias accepted by AbirQu
GOOGLE_PROJECT_ID=

# Optional provider-specific extras
RIGETTI_API_KEY=
QUANTINUUM_API_KEY=
